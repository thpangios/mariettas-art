---
import Base from "../layouts/Base.astro";
---

<Base title="Not found" noindex>
  <section class="section">
    <div class="container center">
      <p class="eyebrow">404</p>
      <h1 class="display">Nothing hanging here.</h1>
      <p class="lede">The page you were looking for has moved, or never existed.</p>
      <p class="cta"><a class="btn btn-primary" href="/">Back to the gallery</a></p>
    </div>
  </section>
</Base>

<style>
  .center { text-align: center; max-width: 40rem; margin-inline: auto; padding-block: clamp(3rem, 8vw, 6rem); }
  .center .eyebrow { margin-bottom: 1rem; }
  .center .lede { margin: 1.25rem auto 0; }
  .cta { margin-top: 2rem; }
</style>
