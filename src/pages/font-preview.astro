---
import "../styles/global.css";

const fontOptions = [
  {
    name: "Marck Script",
    className: "font-marck-script",
    note: "Gentle, painterly, easy to read",
  },
  {
    name: "Mea Culpa",
    className: "font-mea-culpa",
    note: "Expressive and dramatic with sweeping strokes",
  },
  {
    name: "Birthstone",
    className: "font-birthstone",
    note: "Fluid and elegant, like ink on paper",
  },
  {
    name: "WindSong",
    className: "font-windsong",
    note: "Delicate and airy with a lighter touch",
  },
  {
    name: "Luxurious Script",
    className: "font-luxurious-script",
    note: "More composed, still artistic and refined",
  },
  {
    name: "Qwitcher Grypen",
    className: "font-qwitcher-grypen",
    note: "Loose, hand-drawn, and a little wild",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Marietta Font Preview</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Birthstone&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300&family=Inter:wght@400;500;600&family=Luxurious+Script&family=Marck+Script&family=Mea+Culpa&family=Qwitcher+Grypen:wght@400;700&family=WindSong:wght@400;500&display=swap"
    />
  </head>
  <body class="font-preview-page">
    <main class="font-preview">
      <header class="font-preview__header">
        <p class="eyebrow">Font Sampler</p>
        <h1 class="font-preview__title">Choose the voice for Marietta.</h1>
        <p class="font-preview__lede">
          These are all live font options on your site. Pick the one you want and I’ll apply it to the homepage.
        </p>
      </header>

      <section class="font-preview__grid" aria-label="Font choices">
        {fontOptions.map((font, index) => (
          <article class="font-card">
            <div class="font-card__meta">
              <span class="font-card__index">0{index + 1}</span>
              <div>
                <h2 class="font-card__name">{font.name}</h2>
                <p class="font-card__note">{font.note}</p>
              </div>
            </div>
            <div class={`font-card__sample ${font.className}`}>Marietta</div>
          </article>
        ))}
      </section>
    </main>
  </body>
</html>

<style>
  .font-preview-page {
    min-height: 100svh;
    background:
      radial-gradient(circle at top left, color-mix(in oklab, var(--cream) 92%, white) 0%, transparent 42%),
      linear-gradient(180deg, color-mix(in oklab, var(--cream) 96%, white) 0%, var(--cream) 100%);
  }

  .font-preview {
    max-width: 1280px;
    margin-inline: auto;
    padding: clamp(1.5rem, 3vw, 2.75rem) var(--gutter) clamp(3rem, 5vw, 4rem);
  }

  .font-preview__header {
    max-width: 50rem;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .font-preview__title {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 4.75rem);
    font-weight: 300;
    line-height: 0.94;
    letter-spacing: -0.03em;
    margin-top: 0.5rem;
  }

  .font-preview__lede {
    margin-top: 1rem;
    max-width: 42rem;
    color: var(--ink-soft);
    font-size: 1.05rem;
  }

  .font-preview__grid {
    display: grid;
    gap: 1.2rem;
  }

  .font-card {
    padding: clamp(1.2rem, 2.6vw, 1.8rem);
    border: 1px solid color-mix(in oklab, var(--line) 82%, white);
    border-radius: 1.6rem;
    background: color-mix(in oklab, var(--cream) 94%, white);
    box-shadow: 0 1.4rem 2.8rem color-mix(in oklab, var(--accent) 8%, transparent);
  }

  .font-card__meta {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1.4rem;
  }

  .font-card__index {
    display: inline-flex;
    min-width: 2.4rem;
    justify-content: center;
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--line) 78%, white);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .font-card__name {
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .font-card__note {
    margin-top: 0.35rem;
    color: var(--ink-soft);
    font-size: 0.98rem;
  }

  .font-card__sample {
    font-size: clamp(4.8rem, 10vw, 8.8rem);
    line-height: 0.82;
    color: color-mix(in oklab, var(--ink) 92%, var(--accent));
    text-wrap: nowrap;
  }

  .font-marck-script { font-family: "Marck Script", cursive; }
  .font-mea-culpa { font-family: "Mea Culpa", cursive; }
  .font-birthstone { font-family: "Birthstone", cursive; }
  .font-windsong { font-family: "WindSong", cursive; font-weight: 500; }
  .font-luxurious-script { font-family: "Luxurious Script", cursive; }
  .font-qwitcher-grypen { font-family: "Qwitcher Grypen", cursive; font-weight: 700; }

  @media (min-width: 900px) {
    .font-preview__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .font-card__sample {
      font-size: clamp(3.5rem, 17vw, 6.4rem);
    }
  }
</style>
