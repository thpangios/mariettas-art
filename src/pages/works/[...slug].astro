---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";
import { SITE } from "../../consts";

export async function getStaticPaths() {
  const paintings = await getCollection("paintings");
  return paintings.map((p) => ({ params: { slug: p.id }, props: { painting: p } }));
}

const { painting } = Astro.props;
const { Content } = await render(painting);
const d = painting.data;

const ld = {
  "@context": "https://schema.org",
  "@type": "VisualArtwork",
  name: d.title,
  creator: { "@type": "Person", name: SITE.artistName },
  artform: "Painting",
  artMedium: d.medium,
  dateCreated: d.year ? String(d.year) : undefined,
  ...(d.dimensions ? { width: d.dimensions.split("×")[0]?.trim(), height: d.dimensions.split("×")[1]?.trim() } : {}),
  description: d.description,
  image: new URL(d.cover.src, Astro.site ?? SITE.url).toString(),
};

const subject = encodeURIComponent(`Inquiry — ${d.title}${d.year ? ` (${d.year})` : ""}`);
---

<Base
  title={d.title}
  description={d.description ?? `${d.title}. ${d.medium}${d.year ? `, ${d.year}` : ""}.`}
  image={d.cover.src}
  type="article"
  structuredData={ld}
>
  <article class="work theme-mauve">
    <div class="container work__grid">
      <figure class="work__figure">
        <Image
          src={d.cover}
          alt={d.alt}
          widths={[600, 900, 1400, 2000]}
          sizes="(min-width: 900px) 60vw, 90vw"
          loading="eager"
          format="avif"
          quality={88}
          class="work__img"
        />
      </figure>
      <aside class="work__meta">
        <p class="eyebrow">
          <a href={d.category === "paper" ? "/paper-drawings/" : "/canvas/"} class="brush">← {d.category === "paper" ? "All paper drawings" : "All canvas works"}</a>
        </p>
        <h1 class="h1 work__title">{d.title}</h1>
        <dl class="work__dl">
          {d.year && (<><dt>Year</dt><dd>{d.year}</dd></>)}
          <dt>Medium</dt><dd>{d.medium}</dd>
          {d.dimensions && (<><dt>Dimensions</dt><dd>{d.dimensions}</dd></>)}
          <dt>Status</dt>
          <dd>
            <span class={`status status--${d.status}`}>{d.status}</span>
          </dd>
        </dl>

        <div class="work__prose prose">
          <Content />
        </div>

        {d.status === "available" && (
          <div class="work__cta">
            <a
              class="btn btn-primary"
              href={`/contact/?work=${encodeURIComponent(d.title)}`}
            >
              Inquire about this work
            </a>
            <a class="btn" href={`mailto:${SITE.email}?subject=${subject}`}>
              Email directly
            </a>
          </div>
        )}
      </aside>
    </div>
  </article>
</Base>

<style>
  .work { padding-block: clamp(2rem, 5vw, 5rem); }
  .work__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }
  @media (min-width: 900px) {
    .work__grid { grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr); }
    .work__meta { position: sticky; top: 5rem; }
  }
  .work__figure {
    margin: 0;
    background-color: var(--paper-warm);
    overflow: hidden;
  }
  .work__img { width: 100%; height: auto; display: block; }
  .work__title { margin-top: 0.5rem; }
  .work__dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.35rem 1.25rem;
    margin-top: 1.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
    font-size: 0.95rem;
  }
  .work__dl dt {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    padding-top: 0.15rem;
  }
  .work__dl dd { margin: 0; font-family: var(--font-serif); }
  .status {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .status--available { color: var(--cobalt); }
  .status--sold { color: var(--ink-muted); }
  .status--reserved { color: var(--ember); }
  .work__prose { margin-top: 1.75rem; font-size: 1rem; color: var(--ink-soft); }
  .work__cta {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
</style>
