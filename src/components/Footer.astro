---
import { SITE } from "../consts";
const year = new Date().getFullYear();

// Palette pulled from her actual paintings — shown as a hand-painted chip strip
const palette = [
  { c: "#1f1a17", name: "Ink black" },
  { c: "#7e5a65", name: "Dusty wine" },
  { c: "#c7a8b2", name: "Mauve" },
  { c: "#eaddc6", name: "Cream" },
  { c: "#c9341f", name: "Sun red" },
  { c: "#234b7a", name: "Cobalt" },
  { c: "#8b5a3c", name: "Studio brown" },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer__palette" aria-label="Studio palette">
      <p class="eyebrow footer__palette-label">From the Palette</p>
      <ul class="swatches">
        {palette.map((s) => (
          <li>
            <span class="swatch" style={`--c:${s.c}`} title={s.name}></span>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer__inner">
      <div class="footer__email-block">
        <p class="eyebrow">Inquiries</p>
        <p class="footer__email">
          <a href={`mailto:${SITE.email}`} class="brush">{SITE.email}</a>
        </p>
      </div>
      <div class="footer__meta">
        <p>© {year} {SITE.artistName}<i class="flourish flourish--small" aria-hidden="true"></i></p>
        <p class="muted">{SITE.location}</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: clamp(4rem, 8vw, 8rem);
    padding-block: 3rem;
    border-top: 1px solid var(--line);
  }
  .footer__palette {
    margin-bottom: 2.5rem;
    display: grid;
    gap: 0.75rem;
  }
  .footer__palette-label { color: var(--ink-muted); }
  .swatches { list-style: none; padding: 0; margin: 0; }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: space-between;
    align-items: end;
  }
  .footer__email {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--step-1);
    margin-top: 0.5rem;
  }
  .footer__meta {
    text-align: right;
    font-size: 0.9rem;
    color: var(--ink-soft);
  }
  .footer__meta .muted { color: var(--ink-muted); }
  @media (max-width: 520px) {
    .footer__meta { text-align: left; }
  }
</style>
